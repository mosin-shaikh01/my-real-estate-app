# Copy to .env and fill in. .env is gitignored -- never commit real secrets.
#
# Windows note: if your Postgres password contains special characters they MUST
# be URL-encoded here (@ -> %40, # -> %23, etc). Generating an alphanumeric-only
# password avoids the whole problem.
DATABASE_URL="postgresql://crm_app:CHANGEME@localhost:5432/real_estate_crm?schema=public"

# development | production | test. In production, auth cookies are set `secure`
# (HTTPS-only) and the API also serves the built SPA (see SERVE_WEB).
NODE_ENV=development
PORT=4000
# The browser origin. In dev this is the Vite server; in a single-origin
# production deploy it's the app's own public URL (e.g. https://crm.example.com).
WEB_ORIGIN=http://localhost:5173

# Secrets — REQUIRED, must each be >= 32 chars. The app refuses to boot without
# them. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="CHANGEME"
JWT_REFRESH_SECRET="CHANGEME"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Where uploaded media is written. Media is served through an authorized route,
# never static hosting. In production point this at a PERSISTENT, WRITABLE volume
# (e.g. /data/uploads) — a serverless/ephemeral filesystem will lose uploads.
UPLOAD_DIR=./uploads

# console = log reset links to stdout. smtp = real transport (see Mailer).
MAILER=console

# ---- Deployment (production) -------------------------------------------------
# Serve the built SPA (apps/web/dist) from this same process so the whole app is
# one origin. Defaults to on when NODE_ENV=production; set explicitly to decouple
# the frontend behind a reverse proxy. Values: true | false | 1 | 0.
# SERVE_WEB=true
# Absolute path to the built SPA if it isn't the default apps/web/dist.
# WEB_DIST_DIR=/app/apps/web/dist
