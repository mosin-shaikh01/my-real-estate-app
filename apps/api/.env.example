# Copy to .env and fill in. .env is gitignored -- never commit real secrets.
#
# Windows note: if your Postgres password contains special characters they MUST
# be URL-encoded here (@ -> %40, # -> %23, etc). Generating an alphanumeric-only
# password avoids the whole problem.
DATABASE_URL="postgresql://crm_app:CHANGEME@localhost:5432/real_estate_crm?schema=public"

NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="CHANGEME"
JWT_REFRESH_SECRET="CHANGEME"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

UPLOAD_DIR=./uploads

# console = log reset links to stdout. smtp = real transport (see Mailer).
MAILER=console
