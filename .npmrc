# Why this file exists
# ---------------------
# Production hosts (Render, Railway, Hostinger, Vercel, most CI) set
# NODE_ENV=production. With that set, `npm install` / `npm ci` OMIT
# devDependencies by default. But this project's BUILD needs devDependencies:
#   - vite, @vitejs/plugin-react, @tailwindcss/vite, typescript  (build the SPA)
#   - prisma                                                     (generate client / migrate deploy)
# Omitting them breaks `vite build` ("cannot find package 'vite'") and the
# Prisma CLI steps.
#
# `include=dev` forces dev dependencies to be installed even under
# NODE_ENV=production (when a type is in both include and omit, include wins).
# This app builds AND runs as a single service and never prunes to a prod-only
# tree, so installing the full dependency set is the correct, intended behavior —
# not a workaround. It makes `npm ci && npm run build` succeed on every platform
# with no per-host flags or command changes.
include=dev

# Faster, quieter installs on CI/hosts. Harmless locally.
fund=false
audit=false
